# .htaccess — Configuration Apache pour SEO et Performance
# Mosquée Lumière et Piété Nîmes

# ════════════════════════════════════════════════════════════
# 1. REDIRECTION HTTPS (Sécurité + SEO)
# ════════════════════════════════════════════════════════════
# ⚠️ Décommenter quand vous avez un certificat SSL

# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>


# ════════════════════════════════════════════════════════════
# 2. COMPRESSION GZIP (Performance - Vitesse de chargement)
# ════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
  # Compresser HTML, CSS, JavaScript, JSON, XML
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>


# ════════════════════════════════════════════════════════════
# 3. CACHE NAVIGATEUR (Performance)
# ════════════════════════════════════════════════════════════
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images (cache 1 mois)
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS et JavaScript (cache 1 semaine)
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  
  # Polices (cache 1 an)
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  
  # HTML (pas de cache - pour les mises à jour immédiates)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>


# ════════════════════════════════════════════════════════════
# 4. REDIRECTION WWW → sans WWW (ou inverse)
# ════════════════════════════════════════════════════════════
# ⚠️ MODIFIER : choisir UNE SEULE version (avec ou sans www)

# Option A : Rediriger www.site.com → site.com (RECOMMANDÉ)
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTP_HOST} ^www\.mosquee-lumiere-piete-nimes\.fr$ [NC]
#   RewriteRule ^(.*)$ https://mosquee-lumiere-piete-nimes.fr/$1 [R=301,L]
# </IfModule>

# Option B : Rediriger site.com → www.site.com
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTP_HOST} ^mosquee-lumiere-piete-nimes\.fr$ [NC]
#   RewriteRule ^(.*)$ https://www.mosquee-lumiere-piete-nimes.fr/$1 [R=301,L]
# </IfModule>


# ════════════════════════════════════════════════════════════
# 5. PAGES D'ERREUR PERSONNALISÉES
# ════════════════════════════════════════════════════════════
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html


# ════════════════════════════════════════════════════════════
# 6. SÉCURITÉ (Protection contre injections, XSS)
# ════════════════════════════════════════════════════════════

# Bloquer l'accès aux fichiers sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Protection XSS (Cross-Site Scripting)
<IfModule mod_headers.c>
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>


# ════════════════════════════════════════════════════════════
# 7. REDIRECTIONS SPÉCIFIQUES (si besoin)
# ════════════════════════════════════════════════════════════
# Exemple : rediriger une ancienne URL vers la nouvelle
# Redirect 301 /ancienne-page.html https://mosquee-lumiere-piete-nimes.fr/nouvelle-page.html


# ════════════════════════════════════════════════════════════
# 8. TYPE MIME (Reconnaissance des fichiers)
# ════════════════════════════════════════════════════════════
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/manifest+json .webmanifest
</IfModule>


# ════════════════════════════════════════════════════════════
# 9. UTF-8 PAR DÉFAUT (Caractères spéciaux français)
# ════════════════════════════════════════════════════════════
AddDefaultCharset UTF-8
